{
  "info": {
    "_postman_id": "9cb1df11-6d9e-46e2-a843-fbf18b7d2b0f",
    "name": "uy3-leads-api",
    "description": "Collection Postman da API uy3-leads-api. Inclui login, webhook, listagem paginada e exportacao CSV.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "jwt_token",
      "value": ""
    },
    {
      "key": "uy3_webhook_secret",
      "value": ""
    },
    {
      "key": "user_email",
      "value": ""
    },
    {
      "key": "user_password",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Health",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/health",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "health"
          ]
        },
        "description": "Healthcheck simples da API."
      },
      "response": []
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test(\"status 200\", function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "",
                  "var data = pm.response.json();",
                  "if (data.token) {",
                  "  pm.collectionVariables.set(\"jwt_token\", data.token);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{user_email}}\",\n  \"password\": \"{{user_password}}\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/login",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "login"
              ]
            },
            "description": "Autentica um usuario e salva o JWT automaticamente na variavel `jwt_token`."
          },
          "response": []
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/me",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "me"
              ]
            },
            "description": "Retorna os dados do usuario autenticado."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Webhook",
      "item": [
        {
          "name": "Receive Lead",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "X-UY3-Secret-Key",
                "value": "{{uy3_webhook_secret}}"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"cpf\": \"63430832357\",\n  \"is_mei\": false,\n  \"status\": \"ATIVA\",\n  \"typeWebook\": \"LEADS_CLT\",\n  \"dataAdmissao\": \"08102025\",\n  \"valorLiberado\": 1500,\n  \"dataNascimento\": \"09072006\",\n  \"numeroParcelas\": 7,\n  \"nomeTrabalhador\": \"KAUE DO NASCIMENTO MORAIS\",\n  \"codigoRequisicao\": \"23fafd80-07e1-492d-b671-a202e4b51ee8\",\n  \"margemDisponivel\": 320.76,\n  \"active_fgts_debts\": null,\n  \"elegivelEmprestimo\": true,\n  \"all_branch_employees\": null,\n  \"is_judicial_recovery\": false,\n  \"numeroInscricaoEmpregador\": \"30045533\",\n  \"pessoaExpostaPoliticamente\": {\n    \"Codigo\": 0,\n    \"Descricao\": \"Pessoa Nao Exposta Politicamente\"\n  },\n  \"dataHoraValidadeSolicitacao\": \"05052026111027\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/webhook",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "webhook"
              ]
            },
            "description": "Envia um lead bruto para a API com o header de autenticacao do parceiro UY3."
          },
          "response": []
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "List Leads",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/leads?page=1&per_page=20&period=all&sort=received_at&direction=desc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leads"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "20"
                },
                {
                  "key": "period",
                  "value": "all"
                },
                {
                  "key": "sort",
                  "value": "received_at"
                },
                {
                  "key": "direction",
                  "value": "desc"
                }
              ]
            },
            "description": "Lista leads paginados para o frontend."
          },
          "response": []
        },
        {
          "name": "List Leads by Period 7d",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/leads?page=1&per_page=20&period=7d&sort=id&direction=asc",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leads"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "per_page",
                  "value": "20"
                },
                {
                  "key": "period",
                  "value": "7d"
                },
                {
                  "key": "sort",
                  "value": "id"
                },
                {
                  "key": "direction",
                  "value": "asc"
                }
              ]
            },
            "description": "Exemplo de listagem filtrando pelos ultimos 7 dias."
          },
          "response": []
        },
        {
          "name": "List Leads by Date/Time Range",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/leads?period=custom&from=2026-05-09T10:30&to=2026-05-09T12:45",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leads"
              ],
              "query": [
                {
                  "key": "period",
                  "value": "custom"
                },
                {
                  "key": "from",
                  "value": "2026-05-09T10:30"
                },
                {
                  "key": "to",
                  "value": "2026-05-09T12:45"
                }
              ]
            },
            "description": "Exemplo de resumo usando `from` e `to` com data e hora. Datas sem hora continuam aceitas por compatibilidade."
          },
          "response": []
        },
        {
          "name": "Export Leads CSV",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{jwt_token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/leads/export?period=custom&from=2026-05-09T10:30&to=2026-05-09T12:45",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "leads",
                "export"
              ],
              "query": [
                {
                  "key": "period",
                  "value": "custom"
                },
                {
                  "key": "from",
                  "value": "2026-05-09T10:30"
                },
                {
                  "key": "to",
                  "value": "2026-05-09T12:45"
                }
              ]
            },
            "description": "Faz o download do CSV com BOM UTF-8 e delimitador `;`. Aceita `from` e `to` com data e hora."
          },
          "response": []
        }
      ]
    }
  ]
}
